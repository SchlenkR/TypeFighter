{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "strict": true,
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "noImplicitAny": true,
        "noFallthroughCasesInSwitch": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "isolatedModules": true,
        "allowJs": true,
        "lib": ["ES2022", "DOM"]
    },
    "include": ["src/**/*.ts", "fable-out/**/*.js"]
}
